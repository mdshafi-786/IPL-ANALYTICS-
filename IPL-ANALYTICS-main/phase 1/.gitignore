# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
# Checkpoint files created by Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Data files ────────────────────────────────────────────────────────────────
# Raw / processed CSVs (can be large; distribute separately)
*.csv
*.tsv

# Other common data formats
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.sqlite
*.db

# ── Output charts ─────────────────────────────────────────────────────────────
# Generated PNGs are reproducible from the notebook; skip them in version control
*.png
*.jpg
*.jpeg
*.svg
*.pdf

# But keep the curated assets tracked
!assets/
!assets/**

# ── OS & editor noise ─────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# Linux
*~

# VS Code
.vscode/

# JetBrains / PyCharm
.idea/
*.iml

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
