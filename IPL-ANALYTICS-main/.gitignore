*.joblib
models/checkpoints/
runs/

# ── Streamlit ────────────────────────────────────────────
.streamlit/secrets.toml

# ── IDEs & Editors ───────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── Logs & Temp ──────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig
logs/
temp/
tmp/

# ── Environment Variables ────────────────────────────────
.env
.env.local
.env.*.local

# ── Coverage & Testing ───────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
